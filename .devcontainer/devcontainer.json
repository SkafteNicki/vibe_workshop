{
  "name": "OpenCode Workspace",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": []
    }
  },
  "postCreateCommand": "bash /usr/local/bin/check-versions.sh",
  "remoteUser": "vscode"
}
